# ═══════════════════════════════════════════════════════════════════════════
# CANDLESCOUT PRO CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# ── DATABASE ────────────────────────────────────────────────────────
DB_NAME=candlescout
DB_USER=candlescout
DB_PASSWORD=change_me_in_production
DB_HOST=timescaledb
DB_PORT=5432
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ── REDIS ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_DB=1
REDIS_PUBSUB_DB=2
REDIS_MAX_CONNECTIONS=50

# ── DJANGO ───────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change_me_in_production_use_50_chars_minimum_length
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api-service
FERNET_KEY=your_fernet_key_base64_here_generate_with_cryptography

# ── BINANCE (data source) ─────────────────────────────────────────────
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
BINANCE_REST_URL=https://api.binance.com/api/v3
BINANCE_SYMBOL=SOLUSDT
BINANCE_INTERVAL=15m
BINANCE_RECONNECT_DELAYS=1,2,5,10,30
BINANCE_BACKFILL_LIMIT=1000

# ── BYBIT ────────────────────────────────────────────────────────────
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here
BYBIT_TESTNET=true
BYBIT_BASE_URL=https://api-testnet.bybit.com
BYBIT_ACCOUNT_TYPE=UNIFIED
BYBIT_LEVERAGE=5
BYBIT_RECV_WINDOW=5000

# ── OKX ──────────────────────────────────────────────────────────────
OKX_API_KEY=your_okx_api_key_here
OKX_API_SECRET=your_okx_api_secret_here
OKX_PASSPHRASE=your_okx_passphrase_here
OKX_TESTNET=true
OKX_BASE_URL=https://www.okx.com
OKX_LEVERAGE=5
OKX_MARGIN_MODE=cross

# ── ROUTING ──────────────────────────────────────────────────────────
ACTIVE_EXCHANGES=bybit,okx
ROUTING_MODE=best_spread
PRIMARY_EXCHANGE=bybit
SPLIT_RATIO=0.5

# ── RISK MANAGEMENT ──────────────────────────────────────────────────
RISK_PER_TRADE_PCT=1.0
MAX_OPEN_POSITIONS=3
MAX_DAILY_LOSS_PCT=2.0
MAX_DRAWDOWN_PCT=5.0
MIN_CQS_TO_TRADE=65
MIN_RR_RATIO=1.5
COOLDOWN_AFTER_LOSS_MIN=60
PAPER_TRADING=true
MAX_POSITION_SIZE_PCT=20.0

# ── POSITION MANAGEMENT ──────────────────────────────────────────────
MONITORING_INTERVAL_SEC=15
TRAILING_STOP_ENABLED=true
TRAILING_STOP_ACTIVATION_PCT=1.0
TRAILING_STOP_DISTANCE_PCT=0.5
BREAKEVEN_ACTIVATION_PCT=0.5
BREAKEVEN_OFFSET_PCT=0.1
TP1_CLOSE_PCT=50
TP2_CLOSE_PCT=100
ORDER_TYPE=market
LIMIT_OFFSET_PCT=0.05

# ── TELEGRAM ─────────────────────────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_telegram_chat_id
NOTIFY_ON_SIGNAL=true
NOTIFY_ON_ENTRY=true
NOTIFY_ON_EXIT=true
NOTIFY_ON_SL_HIT=true
NOTIFY_ON_BE_MOVE=true
NOTIFY_ON_TRAILING_UPDATE=true
DAILY_REPORT_TIME=23:55
DAILY_REPORT_ENABLED=true

# ── CQS THRESHOLDS ────────────────────────────────────────────────────
CQS_HIGH_THRESHOLD=80
CQS_MEDIUM_THRESHOLD=60
CQS_LOW_THRESHOLD=45
CQS_SIGNAL_THRESHOLD=60

# ── ML MODEL ──────────────────────────────────────────────────────────
ML_MODEL_PATH=/models/xgboost_latest.ubj
ML_RETRAIN_MIN_SAMPLES=500
ML_RETRAIN_SCHEDULE=00:05
ML_MIN_AUC=0.58
ML_MIN_PRECISION=0.55
ML_MIN_RECALL=0.45
ML_MIN_F1=0.50
ML_INFERENCE_TIMEOUT_MS=50

# ── ANALYSIS PIPELINE ─────────────────────────────────────────────────
# Layer 1: Basic Classification
BSS_STRONG_THRESHOLD=70
BSS_MODERATE_THRESHOLD=40
BSS_WEAK_THRESHOLD=10
DOJI_THRESHOLD=0.0005

# Layer 2: Morphology
Z_SCORE_HISTORY_CANDLES=50
MARUBOZU_SHADOW_THRESHOLD=0.05
MARUBOZU_BSS_THRESHOLD=90
HAMMER_LOWER_SHADOW_RATIO=2.0
HAMMER_UPPER_SHADOW_RATIO=0.3

# Layer 3: Context
VOLUME_HISTORY_CANDLES=20
ATR_PERIOD=14
EXTREME_VOLUME_THRESHOLD=3.0
HIGH_VOLUME_THRESHOLD=2.0
LOW_VOLUME_THRESHOLD=0.5
VWAP_THRESHOLD_PCT=0.5
SUSPICIOUS_DELTA_THRESHOLD=-0.2
OFI_THRESHOLD=0.3
FRACTAL_DIMENSION_CANDLES=40

# Layer 4: Patterns
WAVELET_TYPE=db4
WAVELET_LEVEL=3
PATTERN_SCORE_CAP=35

# Layer 5: ML Scoring
CQS_BASE_WEIGHT=0.7
ML_PROBABILITY_WEIGHT=0.3

# ── API SERVICE ───────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false
API_LOG_LEVEL=info
API_CORS_ORIGINS=http://localhost:3000,http://localhost:8080
API_MAX_CONNECTIONS=100

# ── MONITORING ────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── PERFORMANCE ───────────────────────────────────────────────────────
CANDLE_PROCESSING_TIMEOUT_MS=500
SIGNAL_GENERATION_TIMEOUT_MS=500
DB_WRITE_TIMEOUT_MS=100
WS_RECONNECT_TIMEOUT_SEC=60
MAX_CANDLE_LAG_MIN=20

# ── DATA RETENTION ────────────────────────────────────────────────────
CANDLE_RETENTION_MONTHS=12
SIGNAL_RETENTION_MONTHS=12
COMPRESSION_AFTER_DAYS=7
BACKUP_ENABLED=true
BACKUP_SCHEDULE=02:00
