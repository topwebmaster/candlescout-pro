# ── DATABASE ────────────────────────────────────────────────────
DB_NAME=candlescout
DB_USER=candlescout
DB_PASSWORD=change_me_in_production
DB_HOST=timescaledb
DB_PORT=5432

# ── REDIS ────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── DJANGO ───────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change_me_in_production_use_50_chars
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
FERNET_KEY=your_fernet_key_base64_here

# ── BINANCE (data source) ─────────────────────────────────────────
BINANCE_SYMBOL=SOLUSDT
BINANCE_INTERVAL=15m

# ── BYBIT ────────────────────────────────────────────────────────
BYBIT_API_KEY=your_bybit_api_key
BYBIT_API_SECRET=your_bybit_api_secret
BYBIT_TESTNET=true
BYBIT_ACCOUNT_TYPE=UNIFIED
BYBIT_LEVERAGE=5

# ── OKX ──────────────────────────────────────────────────────────
OKX_API_KEY=your_okx_api_key
OKX_API_SECRET=your_okx_api_secret
OKX_PASSPHRASE=your_okx_passphrase
OKX_TESTNET=true
OKX_LEVERAGE=5
OKX_MARGIN_MODE=cross

# ── ROUTING ──────────────────────────────────────────────────────
ACTIVE_EXCHANGES=bybit,okx
ROUTING_MODE=best_spread
PRIMARY_EXCHANGE=bybit
SPLIT_RATIO=0.5

# ── RISK MANAGEMENT ──────────────────────────────────────────────
RISK_PER_TRADE_PCT=1.0
MAX_OPEN_POSITIONS=3
MAX_DAILY_LOSS_PCT=3.0
MAX_DRAWDOWN_PCT=8.0
MIN_CQS_TO_TRADE=65
MIN_RR_RATIO=1.5
COOLDOWN_AFTER_LOSS_MIN=30
PAPER_TRADING=true

# ── POSITION MANAGEMENT ──────────────────────────────────────────
TRAILING_STOP_ENABLED=true
TRAILING_STOP_ACTIVATION_PCT=1.5
TRAILING_STOP_DISTANCE_PCT=0.8
BREAKEVEN_ACTIVATION_PCT=1.0
PARTIAL_CLOSE_TP1_PCT=50
ORDER_TYPE=limit
LIMIT_OFFSET_PCT=0.05

# ── TELEGRAM ─────────────────────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id
NOTIFY_ON_ENTRY=true
NOTIFY_ON_EXIT=true
NOTIFY_ON_SL_HIT=true
NOTIFY_ON_BE_MOVE=true
DAILY_REPORT_TIME=23:55

# ── CQS THRESHOLDS ────────────────────────────────────────────────
CQS_HIGH_THRESHOLD=75
CQS_MEDIUM_THRESHOLD=60
CQS_LOW_THRESHOLD=45

# ── ML ────────────────────────────────────────────────────────────
ML_MODEL_PATH=models/xgboost_latest.ubj
ML_RETRAIN_MIN_SAMPLES=500
ML_RETRAIN_SCHEDULE_HOURS=24
